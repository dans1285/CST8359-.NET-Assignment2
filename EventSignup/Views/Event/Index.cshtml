@model IEnumerable<EventSignup.Models.Event>

@{
    ViewData["Title"] = "Event Manager";
}

<div class="container mt-4">
    <h1 class="mb-4">Event Manager</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Event</a>
    </p>
    
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Date.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@item.Location</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                            <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                            <a asp-action="Delete" asp-route-id="@item.Id">Delete</a> |
                            <a asp-action="ManageAttendees" asp-route-eventId="@item.Id">Attendees</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
