@model EventSignup.Models.Event

@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div>
    @if (!string.IsNullOrEmpty(Model.BannerUrl))
    {
        <img src="@Model.BannerUrl" alt="Banner" class="img-fluid mb-4" style="max-height: 400px; width: 100%; object-fit: cover;" />
    }
    
    <dl class="row">
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.Date.ToString("yyyy-MM-dd HH:mm:ss tt")</dd>
        
        <dt class="col-sm-2">Location</dt>
        <dd class="col-sm-10">@Model.Location</dd>
    </dl>
</div>

<h3>Attendees</h3>
<ul>
    @foreach (var attendee in Model.Attendees)
    {
        <li>@attendee.Name (@attendee.Email)</li>
    }
</ul>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit Event</a>
    <a asp-action="ManageAttendees" asp-route-eventId="@Model.Id" class="btn btn-info">Manage Attendees</a>
    <a asp-action="Index">Back to List</a>
</div>
